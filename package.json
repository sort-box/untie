{
	"name": "untie",
	"version": "0.1.0",
	"description": "TanStack Start desktop app with Electron, Convex, Clerk, and shadcn/ui",
	"private": true,
	"license": "UNLICENSED",
	"type": "module",
	"packageManager": "bun@1.3.5",
	"main": "electron/main.cjs",
	"imports": {
		"#/*": "./src/*"
	},
	"scripts": {
		"dev": "concurrently --kill-others --names convex,web --prefix-colors yellow,cyan \"bun run dev:convex\" \"bun run dev:web\"",
		"dev:convex": "convex dev",
		"dev:web": "vite dev --port 3000",
		"dev:desktop": "concurrently --kill-others --names convex,web,desktop --prefix-colors yellow,cyan,magenta \"bun run dev:convex\" \"bun run dev:web\" \"wait-on tcp:3000 && electron .\"",
		"generate-routes": "tsr generate",
		"build": "vite build",
		"desktop:pack": "bun run build && electron-builder --dir",
		"desktop:dist": "bun run build && electron-builder",
		"preview": "vite preview",
		"test": "vitest run",
		"spike:r2": "bun run src/server/llm/sort-plan-spike/runner.ts",
		"typecheck": "tsc --noEmit",
		"format": "biome format",
		"lint": "biome lint",
		"check": "biome check"
	},
	"dependencies": {
		"@clerk/tanstack-react-start": "^1.4.19",
		"@convex-dev/react-query": "0.1.0",
		"@tailwindcss/vite": "^4.1.18",
		"@tanstack/react-devtools": "latest",
		"@tanstack/react-router": "latest",
		"@tanstack/react-router-devtools": "latest",
		"@tanstack/react-router-ssr-query": "latest",
		"@tanstack/react-start": "latest",
		"@tanstack/router-plugin": "^1.132.0",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"convex": "^1.32.0",
		"lucide-react": "^0.577.0",
		"react": "^19.2.0",
		"react-dom": "^19.2.0",
		"tailwind-merge": "^3.0.2",
		"tailwindcss": "^4.1.18",
		"tw-animate-css": "^1.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.5",
		"@tailwindcss/typography": "^0.5.16",
		"@tanstack/devtools-vite": "latest",
		"@tanstack/router-cli": "^1.132.0",
		"@testing-library/dom": "^10.4.1",
		"@testing-library/react": "^16.3.0",
		"@types/node": "^22.10.2",
		"@types/react": "^19.2.0",
		"@types/react-dom": "^19.2.0",
		"@vitejs/plugin-react": "^6.0.1",
		"concurrently": "^10.0.3",
		"electron": "^43.1.1",
		"electron-builder": "^26.15.3",
		"jsdom": "^28.1.0",
		"typescript": "^6.0.2",
		"vite": "^8.0.0",
		"vitest": "^4.1.5",
		"wait-on": "^9.0.10"
	},
	"trustedDependencies": [
		"@tailwindcss/oxide",
		"electron",
		"electron-winstaller",
		"esbuild",
		"lightningcss"
	]
}
