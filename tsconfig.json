{
	"include": [
		"src/**/*.ts",
		"src/**/*.tsx",
		"convex/**/*.ts",
		"vite.config.ts"
	],
	"exclude": [
		"convex/_generated",
		".agents",
		".claude",
		"agent",
		"dist",
		"release"
	],
	"compilerOptions": {
		"target": "ES2022",
		"jsx": "react-jsx",
		"module": "ESNext",
		"paths": {
			"#/*": ["./src/*"],
			"@/*": ["./src/*"]
		},
		"lib": ["ES2022", "DOM", "DOM.Iterable"],
		"types": ["vite/client"],

		/* Bundler mode */
		"moduleResolution": "bundler",
		"allowImportingTsExtensions": true,
		"verbatimModuleSyntax": true,
		"noEmit": true,

		/* Linting */
		"skipLibCheck": true,
		"strict": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"noFallthroughCasesInSwitch": true,
		"noUncheckedSideEffectImports": true
	}
}
